    {
      "name": "4. 시뮬레이션",
      "item": [
        {
          "name": "단계 전환 → SIMULATION",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('current_phase = SIMULATION', () => {",
                  "  pm.expect(pm.response.json().current_phase).to.eql('SIMULATION');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/phase",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phase\": \"SIMULATION\"\n}"
            }
          }
        },
        {
          "name": "시뮬레이션 턴 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "",
                  "pm.test('reply 존재', () => {",
                  "  pm.expect(data).to.have.property('reply');",
                  "  pm.expect(data.reply).to.be.a('string').and.not.empty;",
                  "  console.log('환자:', data.reply.substring(0, 80) + '...');",
                  "});",
