{
  "info": {
    "name": "NurseComm API Integration Test",
    "description": "간호 의사소통 시뮬레이터 API 통합 테스트. 순서대로 실행하세요.\n\n1. 기초 데이터 조회\n2. 학습자 등록\n3. 시나리오 생성\n4. 세션 생성 → PBL → 시뮬레이션 → 평가\n5. 교육자 기능",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://34.59.172.47:8080/api/v1" },
    { "key": "learnerId", "value": "" },
    { "key": "documentId", "value": "" },
    { "key": "scenarioId", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "educatorId", "value": "1" }
  ],
  "item": [
    {
      "name": "0. 기초 데이터 조회",
      "item": [
        {
          "name": "질환 문서 목록 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('배열 반환', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.be.an('array').and.not.empty;",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.length > 0) {",
                  "  pm.collectionVariables.set('documentId', data[0].id);",
                  "  console.log('documentId set:', data[0].id, data[0].disease_name);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/documents"
          }
        },
        {
          "name": "질환 문서 단건 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('필수 필드 존재', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('disease_name');",
                  "  pm.expect(data).to.have.property('category_path');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/documents/{{documentId}}"
          }
        },
        {
          "name": "평가 도구 목록 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('배열 반환', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.be.an('array');",
                  "});",
                  "console.log('평가 도구:', JSON.stringify(pm.response.json().map(t => ({id: t.id, name: t.tool_name}))));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/evaluation-tools"
          }
        }
      ]
    },
    {
      "name": "1. 학습자",
      "item": [
        {
          "name": "학습자 등록",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('필수 필드 반환', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('name');",
                  "  pm.expect(data).to.have.property('email');",
                  "  pm.expect(data).to.have.property('student_number');",
                  "});",
                  "pm.collectionVariables.set('learnerId', pm.response.json().id);",
                  "console.log('learnerId set:', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/learners",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"테스트학생\",\n  \"email\": \"test@univ.ac.kr\",\n  \"student_number\": \"20210999\"\n}"
            }
          }
        },
        {
          "name": "학습자 목록 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('배열 반환', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('session_count/last_session_at 필드 존재', () => {",
                  "  const data = pm.response.json();",
                  "  if (data.length > 0) {",
                  "    pm.expect(data[0]).to.have.property('session_count');",
                  "    pm.expect(data[0]).to.have.property('last_session_at');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/learners"
          }
        },
        {
          "name": "학습자 단건 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('id 일치', () => {",
                  "  pm.expect(pm.response.json().id).to.eql(Number(pm.collectionVariables.get('learnerId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/learners/{{learnerId}}"
          }
        }
      ]
    },
    {
      "name": "2. 시나리오 생성 (AI)",
      "item": [
        {
          "name": "시나리오 생성",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "",
                  "pm.test('scenario 객체 반환', () => {",
                  "  pm.expect(data).to.have.property('scenario');",
                  "  pm.expect(data.scenario).to.have.property('id');",
                  "  pm.expect(data.scenario).to.have.property('scenario_text');",
                  "  pm.expect(data.scenario).to.have.property('medical_record');",
                  "  pm.expect(data.scenario).to.have.property('dilemma');",
                  "});",
                  "",
                  "pm.test('initial_state 반환', () => {",
                  "  pm.expect(data).to.have.property('initial_state');",
                  "  pm.expect(data.initial_state).to.have.property('environmental_state');",
                  "  pm.expect(data.initial_state).to.have.property('psychological_state');",
                  "});",
                  "",
                  "// medical_record 내부 구조 확인 (클라이언트 기대: flat {name, age, sex, difficulty})",
                  "pm.test('[확인] medical_record 구조', () => {",
                  "  const mr = data.scenario.medical_record;",
                  "  console.log('medical_record:', JSON.stringify(mr));",
                  "  // 서버가 flat 구조로 수정했는지 확인",
                  "  // pm.expect(mr).to.have.property('name');",
                  "});",
                  "",
                  "// initial_state 내부 구조 확인",
                  "pm.test('[확인] initial_state.environmental_state 구조', () => {",
                  "  const env = data.initial_state.environmental_state;",
                  "  console.log('environmental_state:', JSON.stringify(env));",
                  "  // 클라이언트 기대: { vital_signs: Record<string,string>, other_signs: string }",
                  "});",
                  "",
                  "pm.test('[확인] initial_state.psychological_state 구조', () => {",
                  "  const psy = data.initial_state.psychological_state;",
                  "  console.log('psychological_state:', JSON.stringify(psy));",
                  "  // 클라이언트 기대: { anxiety: number, anger: number, depression: number }",
                  "});",
                  "",
                  "pm.collectionVariables.set('scenarioId', data.scenario.id);",
                  "console.log('scenarioId set:', data.scenario.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/scenarios",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"learner_id\": {{learnerId}},\n  \"document_id\": {{documentId}},\n  \"difficulty\": \"중\"\n}"
            }
          }
        },
        {
          "name": "시나리오 단건 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('시나리오 필드 존재', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('scenario_text');",
                  "  pm.expect(data).to.have.property('medical_record');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/scenarios/{{scenarioId}}"
          }
        }
      ]
    },
    {
      "name": "3. 세션 & PBL",
      "item": [
        {
          "name": "세션 생성",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('세션 필드 확인', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('current_phase');",
                  "  pm.expect(data).to.have.property('session_status');",
                  "  console.log('current_phase:', data.current_phase);",
                  "});",
                  "pm.collectionVariables.set('sessionId', pm.response.json().id);",
                  "console.log('sessionId set:', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"learner_id\": {{learnerId}},\n  \"scenario_id\": {{scenarioId}}\n}"
            }
          }
        },
        {
          "name": "PBL 오프닝 (빈 메시지)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
