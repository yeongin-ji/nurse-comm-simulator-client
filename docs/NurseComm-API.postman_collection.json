                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('reply');",
                  "  pm.expect(data.reply).to.be.a('string').and.not.empty;",
                  "  console.log('AI 동료:', data.reply.substring(0, 80) + '...');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/pbl",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"\"\n}"
            }
          }
        },
        {
          "name": "PBL 턴 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('reply 존재', () => {",
