            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/pbl",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"환자가 호흡 교육을 거부하고 있어요. 먼저 공감적 경청으로 신뢰를 쌓은 뒤, 단계적으로 교육을 시도하면 어떨까요?\"\n}"
            }
