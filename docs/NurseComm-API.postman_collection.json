    {
      "name": "5. 평가",
      "item": [
        {
          "name": "단계 전환 → EVALUATION",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('current_phase = EVALUATION', () => {",
                  "  pm.expect(pm.response.json().current_phase).to.eql('EVALUATION');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/phase",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phase\": \"EVALUATION\"\n}"
            }
          }
        },
        {
          "name": "평가 실행 - Kalamazoo (tool_id=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "",
                  "pm.test('tool_id 반환 확인', () => {",
                  "  // 서버가 tool_id를 반환하는지, tool_version_id를 반환하는지 확인",
                  "  console.log('응답 키:', Object.keys(data));",
                  "  console.log('tool_id:', data.tool_id, 'tool_version_id:', data.tool_version_id);",
                  "});",
                  "",
                  "pm.test('item_scores 존재', () => {",
                  "  pm.expect(data).to.have.property('item_scores');",
                  "});",
                  "",
                  "// 클라이언트 기대: { items: [{label, value}], duration_seconds, turns }",
                  "pm.test('[확인] item_scores 내부 구조', () => {",
                  "  const scores = data.item_scores;",
                  "  console.log('item_scores 타입:', typeof scores, Array.isArray(scores) ? '(배열)' : '(객체)');",
                  "  console.log('item_scores:', JSON.stringify(scores).substring(0, 200));",
                  "  ",
                  "  if (Array.isArray(scores)) {",
