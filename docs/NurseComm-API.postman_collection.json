        },
        {
          "name": "PBL 턴 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "console.log('AI 동료:', pm.response.json().reply?.substring(0, 80) + '...');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/pbl",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"감정을 먼저 인정하고, 환자가 준비됐을 때 호흡법을 안내하겠습니다.\"\n}"
            }
          }
        },
        {
          "name": "PBL 요약 생성 (AI)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "pm.test('201 Created 또는 200 OK', () => {",
                  "  pm.expect(status).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('categories 반환', () => {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('categories');",
                  "  console.log('categories 타입:', typeof data.categories, Array.isArray(data.categories) ? '(배열)' : '');",
                  "});",
                  "",
                  "// 클라이언트 기대 구조: [{name: string, items: string[]}]",
                  "pm.test('[확인] categories 내부 구조', () => {",
                  "  const cats = pm.response.json().categories;",
                  "  if (Array.isArray(cats) && cats.length > 0) {",
                  "    pm.expect(cats[0]).to.have.property('name');",
                  "    pm.expect(cats[0]).to.have.property('items');",
                  "    pm.expect(cats[0].items).to.be.an('array');",
                  "    console.log('첫 카테고리:', cats[0].name, '항목 수:', cats[0].items.length);",
                  "  } else {",
                  "    console.warn('categories가 배열이 아니거나 비어있음:', JSON.stringify(cats));",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/pbl/summary"
          }
        },
        {
          "name": "PBL 요약 조회",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('categories 존재', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('categories');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sessions/{{sessionId}}/pbl/summary"
          }
        }
